<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Portfolio Builder</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

<style>

body{
    margin:0;
    background:#f8fafc;
    font-family:"Segoe UI",sans-serif;
    color:#1e293b;
    
    padding-top: 70px;
}

/* NAVBAR */

/* .navbar{
    background:white;
    padding:20px 0;
    border-bottom:1px solid #e5e7eb;
    position:sticky;
    top:0;
    z-index:1000;
} */

.navbar{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    padding: 14px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;

    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);

    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    z-index: 1000;

    transition: all 0.3s ease;
}
.navbar.scrolled{
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    background: rgba(255, 255, 255, 0.85);
}

.brand{
    font-size:1.5rem;
    font-weight:700;
    color:#0f172a;
    text-decoration:none;
}

.nav-btn{
    padding:10px 22px;
    border-radius:12px;
    text-decoration:none;
    font-weight:600;
    transition:.3s;
}

.login-btn{
    color:#334155;
    border:1px solid #d1d5db;
}

.login-btn:hover{
    background:#f1f5f9;
    color:#0f172a;
}

.register-btn{
    background:#2563eb;
    color:white;
}

.register-btn:hover{
    background:#1d4ed8;
    color:white;
}

/* HERO */

/* .hero{
    padding:90px 0;
} */
 .hero{
    /* padding:70px 0; */
padding: 100px 20px;
    margin-bottom:30px;
}

.hero-tag{
    display:inline-block;
    padding:8px 18px;
    border-radius:30px;
    background:#dbeafe;
    color:#2563eb;
    font-weight:600;
    margin-bottom:20px;
}

.hero h1{
    /* font-size:3.7rem; */

    font-size:3.3rem;
    font-weight:800;
    line-height:1.1;
    margin-bottom:25px;
}

.hero p{
    font-size:1.15rem;
    color:#64748b;
    line-height:1.8;
    margin-bottom:35px;
}

.hero-buttons{
    /* display:flex;
    gap:18px;
    flex-wrap:wrap; */
    display: flex;
    gap: 16px;
    justify-content: center; /* or left if needed */
    flex-wrap: wrap;
}

/* .btn-main{
    background:#2563eb;
    color:white;
    padding:14px 32px;
    border-radius:14px;
    text-decoration:none;
    font-weight:600;
    transition:.3s;
}

.btn-main:hover{
    background:#1d4ed8;
    color:white;
}

.btn-outline-custom{
    border:2px solid #2563eb;
    color:#2563eb;
    padding:14px 32px;
    border-radius:14px;
    text-decoration:none;
    font-weight:600;
    transition:.3s;
}

.btn-outline-custom:hover{
    background:#2563eb;
    color:white;
} */
 .btn-main{
    background:#2563eb;
    color:white;
    padding:14px 32px;
    border-radius:14px;
    text-decoration:none;
    font-weight:600;
    transition: all 0.3s ease;
    display: inline-block;
}

.btn-main:hover{
    background:#1d4ed8;
    color:white;
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(37, 99, 235, 0.35);
}

.btn-outline-custom{
    border:2px solid #2563eb;
    color:#2563eb;
    padding:14px 32px;
    border-radius:14px;
    text-decoration:none;
    font-weight:600;
    transition: all 0.3s ease;
    display: inline-block;
}

.btn-outline-custom:hover{
    background:#2563eb;
    color:white;
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(37, 99, 235, 0.35);
}

/* HERO CARD */

.hero-card{
    background:white;
    border-radius:25px;
    padding:35px;
    /* box-shadow:0 20px 60px rgba(0,0,0,.08); */
    box-shadow:
    0 30px 80px rgba(37,99,235,.12),
    0 10px 30px rgba(0,0,0,.05);
    transition:.4s;
}

.mini-card{
    background:#f8fafc;
    border-radius:16px;
    padding:18px;
    margin-bottom:18px;
}

.mini-title{
    font-weight:700;
    font-size:1.05rem;
}

.mini-sub{
    color:#64748b;
}

/* STATS */

.py-5.bg-white{
    border-top:1px solid #e5e7eb;
    border-bottom:1px solid #e5e7eb;
}

/* FEATURES */

.card{
    transition:.3s;
}

.card:hover{
    transform:translateY(-8px);
}

/* CTA */

section:last-child .card{
    background:linear-gradient(135deg,#2563eb,#1d4ed8);
    color:white;
}

section:last-child p{
    color:#e2e8f0 !important;
}

section:last-child .btn{
    background:white;
    color:#2563eb;
    border:none;
    font-weight:700;
}

section:last-child .btn:hover{
    background:#f1f5f9;
}

/* RESPONSIVE */

@media(max-width:992px){

.hero{
    text-align:center;
}

.hero h1{
    font-size:2.8rem;
}

.hero-buttons{
    justify-content:center;
}

.hero-card{
    margin-top:50px;
}
.hero-card:hover{
    transform:translateY(-10px);
}

.hero-title{
    font-size: 48px;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 16px;
}

.hero-subtitle{
    font-size: 18px;
    color: #6b7280;
    margin-bottom: 28px;
    line-height: 1.6;
}
}


</style>

</head>

<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="container">

    <a href="/" class="brand">
      Portfolio Builder
    </a>

    <div class="d-flex gap-2">

      <a href="/login" class="nav-btn login-btn">
        Login
      </a>

      <a href="/register" class="nav-btn register-btn">
        Get Started
      </a>
      
    </div>

  </div>
</nav>

<!-- HERO -->
<section class="hero">

  <div class="container">

    <div class="row align-items-center">

      <div class="col-lg-7 hero-content">

        <div class="hero-tag">
          🚀 Build Your Digital Identity
        </div>

        <h1>
          Create a Portfolio That Gets You Hired.
        </h1>

        <p>
          Showcase your skills, projects, achievements and resume with a beautiful online portfolio that recruiters and clients will love.
        </p>

        <div class="hero-buttons">

          <a href="/register" class="btn-main">
            Create Portfolio
          </a>

          <a href="#features" class="btn-outline-custom">
            Explore Features
          </a>

        </div>
        

      </div>

      <div class="col-lg-5">

        <div class="hero-card">

          <h4 class="fw-bold mb-4">
            Dashboard Preview
          </h4>

          <div class="mini-card">
            <div class="mini-title">
              👤 Professional Profile
            </div>
            <div class="mini-sub">
              Showcase your experience
            </div>
          </div>

          <div class="mini-card">
            <div class="mini-title">
              💼 Projects
            </div>
            <div class="mini-sub">
              Highlight your best work
            </div>
          </div>

          <div class="mini-card">
            <div class="mini-title">
              🌍 Public Portfolio
            </div>
            <div class="mini-sub">
              Share one beautiful link
            </div>
          </div>

        </div>

      </div>

    </div>

  </div>

</section>

<!-- STATS -->
<section class="py-5 bg-white">

  <div class="container">

    <div class="row text-center g-4">

      <div class="col-md-3">
        <h2 class="fw-bold text-primary">1K+</h2>
        <p class="text-muted">Registered Users</p>
      </div>

      <div class="col-md-3">
        <h2 class="fw-bold text-primary">5K+</h2>
        <p class="text-muted">Projects Published</p>
      </div>

      <div class="col-md-3">
        <h2 class="fw-bold text-primary">99%</h2>
        <p class="text-muted">User Satisfaction</p>
      </div>

      <div class="col-md-3">
        <h2 class="fw-bold text-primary">24/7</h2>
        <p class="text-muted">Portfolio Availability</p>
      </div>

    </div>

  </div>

</section>

<!-- FEATURES -->
<section id="features" class="py-5">

  <div class="container">

    <div class="text-center mb-5">

      <h2 class="fw-bold display-6">
        Everything You Need
      </h2>

      <p class="text-muted">
        Build, manage and share your portfolio with confidence.
      </p>

    </div>

    <div class="row g-4">

      <div class="col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">👤</div>
          <h4>Professional Profile</h4>
          <p class="text-muted">
            Create a clean profile with your education, experience, skills and social links.
          </p>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">💼</div>
          <h4>Project Showcase</h4>
          <p class="text-muted">
            Display GitHub repositories, live demos and project descriptions beautifully.
          </p>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">🌍</div>
          <h4>Public Portfolio</h4>
          <p class="text-muted">
            Share one professional link with recruiters anywhere in the world.
          </p>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">📄</div>
          <h4>Resume Upload</h4>
          <p class="text-muted">
            Upload your CV for recruiters to download.
          </p>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">📊</div>
          <h4>Dashboard</h4>
          <p class="text-muted">
            Track your profile, projects and portfolio growth.
          </p>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">🔒</div>
          <h4>Secure Authentication</h4>
          <p class="text-muted">
            JWT authentication keeps your account secure.
          </p>
        </div>
      </div>

    </div>

  </div>

</section>

<!-- CTA -->
<section class="py-5">

  <div class="container">

    <div class="card border-0 rounded-4 shadow p-5 text-center">

      <h2 class="fw-bold mb-3">
        Ready to Build Your Portfolio?
      </h2>

      <p class="text-muted mb-4">
        Join thousands of developers creating beautiful portfolios in minutes.
      </p>

      <a href="/register" class="btn btn-dark btn-lg px-5">
        Get Started Free
      </a>

    </div>

  </div>

</section>
<script>
window.addEventListener("scroll", function () {
    const navbar = document.querySelector(".navbar");

    if (window.scrollY > 10) {
        navbar.classList.add("scrolled");
    } else {
        navbar.classList.remove("scrolled");
    }
});
</script>

</body>

