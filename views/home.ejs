<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Portfolio Builder</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    margin:0;
    background:#f8fafc;
    font-family:"Inter","Segoe UI",sans-serif;
    color:#1e293b;
    overflow-x:hidden;
    padding-top:80px;
}

/* NAVBAR */

.navbar{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    padding:16px 6%;
    display:flex;
    justify-content:space-between;
    align-items:center;
    background:rgba(255,255,255,.75);
    backdrop-filter:blur(12px);
    -webkit-backdrop-filter:blur(12px);
    border-bottom:1px solid rgba(0,0,0,.06);
    z-index:9999;
    transition:.3s;
}

.navbar.scrolled{
    background:rgba(255,255,255,.95);
    box-shadow:0 10px 30px rgba(0,0,0,.08);
}

.brand{
    font-size:1.6rem;
    font-weight:800;
    color:#0f172a;
    text-decoration:none;
}

.nav-buttons{
    display:flex;
    gap:12px;
}

.nav-btn{
    padding:11px 22px;
    border-radius:12px;
    text-decoration:none;
    font-weight:600;
    transition:.3s;
}

.login-btn{
    color:#334155;
    border:1px solid #d1d5db;
    background:white;
}

.login-btn:hover{
    background:#f1f5f9;
    color:#0f172a;
}

.register-btn{
    background:#2563eb;
    color:#fff;
}

.register-btn:hover{
    background:#1d4ed8;
    color:#fff;
}

/* HERO */

.hero{
    padding:100px 20px;
    margin-bottom:40px;
}

.hero-tag{
    display:inline-block;
    padding:8px 18px;
    border-radius:999px;
    background:#dbeafe;
    color:#2563eb;
    font-weight:600;
    margin-bottom:20px;
}

.hero h1{
    font-size:3.4rem;
    font-weight:800;
    line-height:1.15;
    margin-bottom:25px;
}

.hero p{
    font-size:1.1rem;
    color:#64748b;
    line-height:1.8;
    margin-bottom:35px;
}

.hero-buttons{
    display:flex;
    gap:16px;
    flex-wrap:wrap;
}

.btn-main,
.btn-outline-custom{
    padding:14px 32px;
    border-radius:14px;
    font-weight:600;
    text-decoration:none;
    transition:.3s;
    display:inline-flex;
    align-items:center;
    justify-content:center;
}

.btn-main{
    background:#2563eb;
    color:#fff;
}

.btn-main:hover{
    background:#1d4ed8;
    color:#fff;
    transform:translateY(-3px);
    box-shadow:0 12px 25px rgba(37,99,235,.3);
}

.btn-outline-custom{
    border:2px solid #2563eb;
    color:#2563eb;
}

.btn-outline-custom:hover{
    background:#2563eb;
    color:#fff;
    transform:translateY(-3px);
}

/* HERO CARD */

.hero-card{
    background:#fff;
    border-radius:24px;
    padding:35px;
    box-shadow:
    0 30px 80px rgba(37,99,235,.12),
    0 10px 30px rgba(0,0,0,.05);
    transition:.35s;
}

.hero-card:hover{
    transform:translateY(-8px);
}

.mini-card{
    background:#f8fafc;
    border-radius:16px;
    padding:18px;
    margin-bottom:18px;
}

.mini-title{
    font-weight:700;
}

.mini-sub{
    color:#64748b;
}

/* STATS */

.py-5.bg-white{
    border-top:1px solid #e5e7eb;
    border-bottom:1px solid #e5e7eb;
}

/* FEATURES */

.card{
    border:none;
    border-radius:18px;
    transition:.3s;
    box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.card:hover{
    transform:translateY(-8px);
}

/* CTA */

section:last-child .card{
    background:linear-gradient(135deg,#2563eb,#1d4ed8);
    color:#fff;
}

section:last-child p{
    color:#e2e8f0!important;
}

section:last-child .btn{
    background:#fff;
    color:#2563eb;
    border:none;
    font-weight:700;
}

/* ===========================
TABLET
=========================== */

@media (max-width:992px){

.hero{
    text-align:center;
}

.hero h1{
    font-size:2.7rem;
}

.hero-buttons{
    justify-content:center;
}

.hero-card{
    margin-top:40px;
}

}

/* ===========================
MOBILE
=========================== */

@media (max-width:768px){

body{
    padding-top:70px;
}

.navbar{
    flex-direction:column;
    gap:15px;
    padding:15px;
}

.nav-buttons{
    width:100%;
    justify-content:center;
    flex-wrap:wrap;
}

.nav-btn{
    width:150px;
    text-align:center;
}

.hero{
    padding:60px 20px;
}

.hero h1{
    font-size:2.2rem;
}

.hero p{
    font-size:1rem;
}

.hero-buttons{
    flex-direction:column;
    align-items:center;
}

.btn-main,
.btn-outline-custom{
    width:100%;
    max-width:300px;
}

.hero-card{
    padding:25px;
    margin-top:35px;
}

}

/* SMALL PHONES */

@media (max-width:480px){

.hero h1{
    font-size:1.9rem;
}

.brand{
    font-size:1.3rem;
}

.nav-btn{
    width:100%;
}

}

</style>

</head>

<body>

<!-- NAVBAR -->
<nav class="navbar">

    <div class="container d-flex justify-content-between align-items-center">

        <a href="/" class="brand">
            Portfolio Builder
        </a>

        <div class="nav-buttons">

            <a href="/login" class="nav-btn login-btn">
                Login
            </a>

            <a href="/register" class="nav-btn register-btn">
                Get Started
            </a>

        </div>

    </div>

</nav>

<!-- HERO -->
<section class="hero">

    <div class="container">

        <div class="row align-items-center gy-5">

            <div class="col-lg-7 text-center text-lg-start">

                <div class="hero-tag">
                    🚀 Build Your Digital Identity
                </div>

                <h1>
                    Create a Portfolio That Gets You Hired.
                </h1>

                <p>
                    Showcase your skills, projects, achievements with a beautiful online portfolio that recruiters and clients will love.
                </p>

                <div class="hero-buttons">

                    <a href="/register" class="btn-main">
                        Create Portfolio
                    </a>

                    <a href="#features" class="btn-outline-custom">
                        Explore Features
                    </a>

                </div>

            </div>

            <div class="col-lg-5">

                <div class="hero-card">

                    <h4 class="fw-bold mb-4">
                        Dashboard Preview
                    </h4>

                    <div class="mini-card">
                        <div class="mini-title">👤 Professional Profile</div>
                        <div class="mini-sub">Showcase your experience</div>
                    </div>

                    <div class="mini-card">
                        <div class="mini-title">💼 Projects</div>
                        <div class="mini-sub">Highlight your best work</div>
                    </div>

                    <div class="mini-card">
                        <div class="mini-title">🌍 Public Portfolio</div>
                        <div class="mini-sub">Share one beautiful link</div>
                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- STATS -->
<section class="py-5 bg-white">

  <div class="container">

    <div class="row text-center g-4">

      <div class="col-6 col-md-3">
        <h2 class="fw-bold text-primary">1K+</h2>
        <p class="text-muted">Registered Users</p>
      </div>

      <div class="col-6 col-md-3">
        <h2 class="fw-bold text-primary">5K+</h2>
        <p class="text-muted">Projects Published</p>
      </div>

      <div class="col-6 col-md-3">
        <h2 class="fw-bold text-primary">99%</h2>
        <p class="text-muted">User Satisfaction</p>
      </div>

      <div class="col-6 col-md-3">
        <h2 class="fw-bold text-primary">24/7</h2>
        <p class="text-muted">Portfolio Availability</p>
      </div>

    </div>

  </div>

</section>

<!-- FEATURES -->
<section id="features" class="py-5">

  <div class="container">

    <div class="text-center mb-5">

      <h2 class="fw-bold display-6">
        Everything You Need
      </h2>

      <p class="text-muted">
        Build, manage and share your portfolio with confidence.
      </p>

    </div>

    <div class="row g-4">

      <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">👤</div>
          <h4>Professional Profile</h4>
          <p class="text-muted">
            Create a clean profile with your education, experience, skills and social links.
          </p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">💼</div>
          <h4>Project Showcase</h4>
          <p class="text-muted">
            Display GitHub repositories, live demos and project descriptions beautifully.
          </p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">🌍</div>
          <h4>Public Portfolio</h4>
          <p class="text-muted">
            Share one professional link with recruiters anywhere in the world.
          </p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">📊</div>
          <h4>Dashboard</h4>
          <p class="text-muted">
            Track your profile, projects and portfolio growth.
          </p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
          <div class="display-5 mb-3">🔒</div>
          <h4>Secure Authentication</h4>
          <p class="text-muted">
            JWT authentication keeps your account secure.
          </p>
        </div>
      </div>

    </div>

  </div>

</section>

<!-- CTA -->
<section class="py-5">

  <div class="container">

    <div class="card border-0 rounded-4 shadow p-5 text-center">

      <h2 class="fw-bold mb-3">
        Ready to Build Your Portfolio?
      </h2>

      <p class="text-muted mb-4">
        Join thousands of developers creating beautiful portfolios in minutes.
      </p>

      <a href="/register" class="btn btn-light btn-lg px-5 fw-bold">
        Get Started Free
      </a>

    </div>

  </div>

</section>

<script>

window.addEventListener("scroll", () => {

    const navbar = document.querySelector(".navbar");

    navbar.classList.toggle("scrolled", window.scrollY > 10);

});

</script>

</body>
