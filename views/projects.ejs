<!DOCTYPE html>
<html>
<head>
  <title>Projects - Portfolio Builder</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    

    body{
    margin:0;
    background:var(--bg);
    font-family:"Segoe UI",sans-serif;
    color:var(--text);
}

    /* SIDEBAR */
    
     .sidebar{
    width:240px;
    height:100vh;
    position:fixed;
    background:var(--card);
    border-right:1px solid var(--border);
    padding:20px;
}

   
     .brand{
    font-size:1.3rem;
    font-weight:700;
    color:var(--primary);
    margin-bottom:30px;
}

    

    .nav-link{
    display:block;
    padding:12px 14px;
    margin-bottom:8px;
    color:var(--muted);
    text-decoration:none;
    border-radius:12px;
    transition:.3s;
}

.nav-link:hover{
    background:#eff6ff;
    color:var(--primary);
}

    /* MAIN */
    .main{
      margin-left:260px;
      padding:30px;
    }

    .title{
      font-size:1.8rem;
      font-weight:700;
      margin-bottom:5px;
    }

    .subtitle{
      color:#6B7280;
      margin-bottom:25px;
    }

    
     .card-box{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:18px;
    padding:24px;
    box-shadow:0 8px 30px rgba(15,23,42,.05);
    transition:.3s;
}

.card-box:hover{
    transform:translateY(-5px);
    box-shadow:0 15px 35px rgba(15,23,42,.08);
}

    /* FORM */
    .form-control{
      border:1px solid #E5E7EB;
      border-radius:10px;
      padding:10px;
    }

    
     .form-control:focus{
    border-color:var(--primary);
    box-shadow:0 0 0 .2rem rgba(37,99,235,.15);
}

   
   
    .btn-custom{
    background:#2563eb;
    color:#fff !important;
    border:none;
    padding:12px 22px;
    border-radius:14px;
    font-weight:600;
    display:inline-block;
    cursor:pointer;
    transition:.3s ease;
}

.btn-custom:hover{
    background:#1d4ed8;
    color:#fff !important;
    transform:translateY(-2px);
}
    
     .project-card{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:18px;
    padding:20px;
    margin-bottom:18px;
    transition:.3s;
    box-shadow:0 6px 20px rgba(15,23,42,.05);
}

.project-card:hover{
    transform:translateY(-4px);
    box-shadow:0 15px 30px rgba(15,23,42,.08);
}

    .project-title{
      font-weight:600;
      font-size:1.1rem;
    }

    .project-desc{
      color:#6B7280;
      font-size:0.9rem;
    }

    .btn-delete{
    background:#dc3545;
    color:#fff;
    border:none;
    padding:12px 22px;
    border-radius:14px;
    font-weight:600;
    cursor:pointer;
    transition:.3s ease;
}

.btn-delete:hover{
    background:#bb2d3b;
    transform:translateY(-2px);
}


  </style>
</head>

<body>

<div class="sidebar">

    <div class="brand">
        Portfolio Builder
    </div>

    <a class="nav-link" href="/dashboard">
        📊 Dashboard
    </a>

    <a class="nav-link" href="/profile">
        👤 Profile
    </a>

    <a class="nav-link" href="/projects">
        💼 Projects
    </a>

    <a class="nav-link" id="portfolioLink">
        🌐 Public Portfolio
    </a>

    <hr>

    <a class="nav-link text-danger" href="#" onclick="logout()">
        🚪 Logout
    </a>

</div>

<!-- MAIN -->
<div class="main">

  <div class="title">Projects</div>
  <div class="subtitle">Add and manage your portfolio projects</div>

  <!-- ADD PROJECT -->
  <div class="card-box mb-4">

    <form id="projectForm">

      <input id="title" class="form-control mb-3" placeholder="Project Title">

      <textarea id="description" class="form-control mb-3" placeholder="Project Description"></textarea>

      <input id="github" class="form-control mb-3" placeholder="GitHub Repository">

      <input id="liveLink" class="form-control mb-3" placeholder="Live Link">

      <button class="btn-custom" type="submit">Add Project</button>

    </form>

  </div>

  <!-- PROJECT LIST -->
  <div id="projectList"></div>

   <!-- EDIT PROJECT MODAL -->
<div class="modal fade" id="editProjectModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Edit Project</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <input type="hidden" id="editProjectId">

        <input
          type="text"
          id="editTitle"
          class="form-control mb-3"
          placeholder="Project Title"
        >

        <textarea
          id="editDescription"
          class="form-control mb-3"
          placeholder="Project Description"
        ></textarea>

        <input
          type="text"
          id="editGithub"
          class="form-control mb-3"
          placeholder="GitHub Repository"
        >

        <input
          type="text"
          id="editLiveLink"
          class="form-control"
          placeholder="Live Link"
        >

      </div>

      <div class="modal-footer">
        <button
          type="button"
          class="btn btn-secondary"
          data-bs-dismiss="modal"
        >
          Cancel
        </button>

        <button
          type="button"
          class="btn-custom"
          onclick="saveProject()"
        >
          Save Changes
        </button>
      </div>

    </div>
  </div>
</div>


</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
const token = localStorage.getItem("token");

if (!token) {
    window.location.href = "/login";
}

// CREATE PROJECT
document.getElementById("projectForm").addEventListener("submit", async (e) => {
    e.preventDefault();

    const title = document.getElementById("title").value;
    const description = document.getElementById("description").value;
    const github = document.getElementById("github").value;
    const liveLink = document.getElementById("liveLink").value;

    const res = await fetch("/api/projects", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + token
        },
        body: JSON.stringify({
            title,
            description,
            github,
            liveLink
        })
    });

    const data = await res.json();

    if (res.ok) {

        alert("Project added!");

        document.getElementById("title").value = "";
        document.getElementById("description").value = "";
        document.getElementById("github").value = "";
        document.getElementById("liveLink").value = "";

        loadProjects();

    } else {

        alert(data.message || "Error");
    }
});

// LOAD PROJECTS
async function loadProjects() {

    const res = await fetch("/api/projects", {
        headers: {
            "Authorization": "Bearer " + token
        }
    });

    const data = await res.json();

    const container = document.getElementById("projectList");
    container.innerHTML = "";

    if (res.ok) {

        data.forEach(p => {

            container.innerHTML += `
            <div class="project-card">

                <div class="project-title">${p.title}</div>

                <div class="project-desc">
                    ${p.description || ""}
                </div>

                ${p.github ? `<a href="${p.github}" target="_blank">GitHub</a><br>` : ""}

                ${p.liveLink ? `<a href="${p.liveLink}" target="_blank">Live Demo</a><br><br>` : "<br>"}

                <button class="btn-custom me-2"
                    onclick="editProject('${p._id}',
                    '${p.title.replace(/'/g, "\\'")}',
                    \`${p.description || ""}\`,
                    '${(p.github || "").replace(/'/g, "\\'")}',
                    '${(p.liveLink || "").replace(/'/g, "\\'")}')">
                    Edit
                </button>

                <button class="btn-delete"
    onclick="deleteProject('${p._id}')">
    Delete
</button>

            </div>
            `;

        });

    }

}

// DELETE PROJECT
async function deleteProject(id) {

    if (!confirm("Delete this project?")) return;

    const res = await fetch("/api/projects/" + id, {
        method: "DELETE",
        headers: {
            "Authorization": "Bearer " + token
        }
    });

    const data = await res.json();

    if (res.ok) {

        alert(data.message);
        loadProjects();

    } else {

        alert(data.message);
    }

}


// EDIT PROJECT
function editProject(id, title, description, github, liveLink) {

    document.getElementById("editProjectId").value = id;
    document.getElementById("editTitle").value = title;
    document.getElementById("editDescription").value = description;
    document.getElementById("editGithub").value = github;
    document.getElementById("editLiveLink").value = liveLink;

    const modal = new bootstrap.Modal(
        document.getElementById("editProjectModal")
    );

    modal.show();
}
async function saveProject() {

    const id = document.getElementById("editProjectId").value;

    const res = await fetch("/api/projects/" + id, {
        method: "PUT",
        headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + token
        },
        body: JSON.stringify({
            title: document.getElementById("editTitle").value,
            description: document.getElementById("editDescription").value,
            github: document.getElementById("editGithub").value,
            liveLink: document.getElementById("editLiveLink").value
        })
    });

    const data = await res.json();

    if (res.ok) {

        bootstrap.Modal
            .getInstance(document.getElementById("editProjectModal"))
            .hide();

        loadProjects();

        alert("Project updated successfully!");

    } else {

        alert(data.message);
    }
}


const username = localStorage.getItem("username");

const portfolioLink = document.getElementById("portfolioLink");

if (portfolioLink) {
    if (username) {
        portfolioLink.href = `/portfolio/${username}`;
    } else {
        portfolioLink.style.display = "none";
    }
}

function logout() {
    localStorage.removeItem("token");
    localStorage.removeItem("username");
    window.location.href = "/login";
}

loadProjects();
</script>

</body>
</html>