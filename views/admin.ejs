<!DOCTYPE html>
<html>

<head>

<title>Admin Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f5f7fb;
font-family:Segoe UI,sans-serif;
}

.sidebar{
width:230px;
height:100vh;
position:fixed;
background:#1F2937;
padding:30px;
color:white;
}

.sidebar h3{
margin-bottom:40px;
}

.sidebar a{
display:block;
color:white;
text-decoration:none;
margin:15px 0;
}

.main{
margin-left:250px;
padding:40px;
}

.card{
border:none;
border-radius:15px;
box-shadow:0 10px 20px rgba(0,0,0,.08);
margin-bottom:25px;
}

</style>

</head>

<body>

<div class="sidebar">

<h3>Admin</h3>

<a href="/dashboard">Dashboard</a>

<a href="/profile">Profile</a>

<a href="/projects">Projects</a>

<a href="#" onclick="logout()">Logout</a>

</div>

<div class="main">

<h2 class="mb-4">Admin Dashboard</h2>

<div class="row mb-4">

<div class="col-md-4">

<div class="card p-4 text-center">

<h3 id="usersCount">0</h3>

<p>Total Users</p>

</div>

</div>

<div class="col-md-4">

<div class="card p-4 text-center">

<h3 id="projectsCount">0</h3>

<p>Total Projects</p>

</div>

</div>

<div class="col-md-4">

<div class="card p-4 text-center">

<h3 id="profilesCount">0</h3>

<p>Total Profiles</p>

</div>

</div>

</div>

<h3>Users</h3>

<table class="table table-bordered">

<thead>

<tr>

<th>Name</th>

<th>Email</th>

<th>Action</th>

</tr>

</thead>

<tbody id="usersTable"></tbody>

</table>

<h3 class="mt-5">Projects</h3>

<table class="table table-bordered">

<thead>

<tr>

<th>Title</th>

<th>Action</th>

</tr>

</thead>

<tbody id="projectsTable"></tbody>

</table>

</div>

<script>

const token=localStorage.getItem("token");

async function loadStats(){

const res=await fetch("/api/admin/stats",{

headers:{Authorization:"Bearer "+token}

});

const data=await res.json();

document.getElementById("usersCount").innerText=data.totalUsers;

document.getElementById("projectsCount").innerText=data.totalProjects;

document.getElementById("profilesCount").innerText=data.totalProfiles;

}

async function loadUsers(){

const res=await fetch("/api/admin/users",{

headers:{Authorization:"Bearer "+token}

});

const users=await res.json();

const table=document.getElementById("usersTable");

table.innerHTML="";

users.forEach(user=>{

table.innerHTML+=`

<tr>

<td>${user.name}</td>

<td>${user.email}</td>

<td>

<button class="btn btn-danger btn-sm"

onclick="deleteUser('${user._id}')">

Delete

</button>

</td>

</tr>

`;

});

}

async function loadProjects(){

const res=await fetch("/api/admin/projects",{

headers:{Authorization:"Bearer "+token}

});

const projects=await res.json();

const table=document.getElementById("projectsTable");

table.innerHTML="";

projects.forEach(project=>{

table.innerHTML+=`

<tr>

<td>${project.title}</td>

<td>

<button class="btn btn-danger btn-sm"

onclick="deleteProject('${project._id}')">

Delete

</button>

</td>

</tr>

`;

});

}

async function deleteUser(id){

await fetch("/api/admin/users/"+id,{

method:"DELETE",

headers:{Authorization:"Bearer "+token}

});

loadUsers();

loadStats();

}

async function deleteProject(id){

await fetch("/api/admin/projects/"+id,{

method:"DELETE",

headers:{Authorization:"Bearer "+token}

});

loadProjects();

loadStats();

}

function logout(){

localStorage.clear();

window.location="/login";

}

loadStats();

loadUsers();

loadProjects();

</script>

</body>

</html>