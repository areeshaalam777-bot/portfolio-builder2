<!DOCTYPE html>
<html>
<head>
    <title>Login - Portfolio Builder</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

   <style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#FAFAF7;
    font-family:"Segoe UI",sans-serif;
    color:#1F2937;
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
}

.login-wrapper{
    width:1000px;
    max-width:100%;
    min-height:620px;
    background:#FFFFFF;
    border:1px solid #E5E7EB;
    border-radius:22px;
    overflow:hidden;
    display:flex;
    box-shadow:0 20px 50px rgba(0,0,0,.08);
}

/* LEFT */

.left-panel{
    width:45%;
    background:linear-gradient(135deg,#334155,#1E293B);
    color:white;
    display:flex;
    flex-direction:column;
    justify-content:center;
    padding:60px;
}

.brand{
    font-size:2rem;
    font-weight:700;
    margin-bottom:20px;
}

.tagline{
    font-size:2.3rem;
    font-weight:700;
    line-height:1.3;
    margin-bottom:20px;
}

.description{
    color:#CBD5E1;
    line-height:1.8;
}

/* RIGHT */

.right-panel{
    width:55%;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:60px;
}

.login-box{
    width:100%;
    max-width:420px;
}

.title{
    font-size:2rem;
    font-weight:700;
    margin-bottom:8px;
}

.subtitle{
    color:#6B7280;
    margin-bottom:35px;
}

.form-control{
    height:52px;
    border-radius:12px;
    border:1px solid #E5E7EB;
    margin-bottom:18px;
}

.form-control:focus{
    border-color:#334155;
    box-shadow:0 0 0 .15rem rgba(51,65,85,.15);
}

.btn-custom{
    width:100%;
    height:52px;
    background:#334155;
    color:white;
    border:none;
    border-radius:12px;
    font-weight:600;
    transition:.3s;
}

.btn-custom:hover{
    background:#1F2937;
}

.bottom-text{
    margin-top:22px;
    text-align:center;
    color:#6B7280;
}

.bottom-text a{
    color:#334155;
    text-decoration:none;
    font-weight:600;
}

/* ---------------- Tablet ---------------- */

@media (max-width:992px){

.login-wrapper{
    flex-direction:column;
    max-width:650px;
}

.left-panel,
.right-panel{
    width:100%;
}

.left-panel{
    padding:45px;
    text-align:center;
}

.right-panel{
    padding:45px 30px;
}

}

/* ---------------- Mobile ---------------- */

@media (max-width:768px){

body{
    padding:15px;
    align-items:flex-start;
}

.login-wrapper{
    border-radius:18px;
    min-height:auto;
}

.left-panel{
    padding:35px 25px;
}

.brand{
    font-size:1.6rem;
}

.tagline{
    font-size:1.8rem;
}

.description{
    font-size:.95rem;
}

.right-panel{
    padding:30px 20px;
}

.title{
    font-size:1.7rem;
    text-align:center;
}

.subtitle{
    text-align:center;
    font-size:.95rem;
}

.form-control{
    height:50px;
}

.btn-custom{
    height:50px;
}

}

/* ---------------- Small Phones ---------------- */

@media (max-width:480px){

body{
    padding:10px;
}

.left-panel{
    padding:30px 20px;
}

.brand{
    font-size:1.4rem;
}

.tagline{
    font-size:1.5rem;
}

.description{
    font-size:.9rem;
}

.right-panel{
    padding:25px 18px;
}

.title{
    font-size:1.5rem;
}

.subtitle{
    font-size:.9rem;
}

}

</style>

</head>

<body>

<div class="login-wrapper">

    <!-- LEFT SIDE -->
    <div class="left-panel">

        <div class="brand">
            Portfolio Builder
        </div>

        <div class="tagline">
            Build Your Digital Identity
        </div>

        <div class="description">
            Showcase your projects, skills, achievements and professional journey through a beautiful online portfolio.
        </div>

    </div>

    <!-- RIGHT SIDE -->
    <div class="right-panel">

        <div class="login-box">

            <div class="title">
                Welcome Back
            </div>

            <div class="subtitle">
                Login to manage your portfolio.
            </div>

            <form id="loginForm">

                <input
                    type="email"
                    id="email"
                    class="form-control"
                    placeholder="Email Address"
                    required
                >

                <input
                    type="password"
                    id="password"
                    class="form-control"
                    placeholder="Password"
                    required
                >

                <div class="d-flex justify-content-end mb-3">
                    <a href="/forgot-password" class="text-decoration-none">
                        Forgot Password?
                    </a>
                </div>

                <button
                    id="loginBtn"
                    class="btn-custom"
                    type="submit">
                    Login
                </button>

            </form>

            <div class="bottom-text">
                Don't have an account?
                <a href="/register">
                    Create Account
                </a>
            </div>

        </div>

    </div>

</div>

<!-- Toast -->
<div id="toast"
style="
position:fixed;
top:20px;
right:20px;
padding:15px 25px;
border-radius:10px;
background:#334155;
color:#fff;
display:none;
z-index:9999;
font-weight:600;
box-shadow:0 10px 30px rgba(0,0,0,.2);
">
</div>

<script>

function showToast(message,type){

    const toast=document.getElementById("toast");

    toast.innerHTML=message;

    toast.style.background=
        type==="success"
        ? "#16a34a"
        : "#dc2626";

    toast.style.display="block";

    setTimeout(()=>{
        toast.style.display="none";
    },2500);

}

const form=document.getElementById("loginForm");
const loginBtn=document.getElementById("loginBtn");

form.addEventListener("submit",async(e)=>{

    e.preventDefault();

    loginBtn.disabled=true;
    loginBtn.innerText="Logging in...";

    const email=document.getElementById("email").value.trim();
    const password=document.getElementById("password").value;

    try{

        const res=await fetch("/api/auth/login",{

            method:"POST",

            headers:{
                "Content-Type":"application/json"
            },

            body:JSON.stringify({
                email,
                password
            })

        });

        const data=await res.json();

        if(!res.ok){

            showToast(
                data.message || "Login failed",
                "danger"
            );

            loginBtn.disabled=false;
            loginBtn.innerText="Login";
            return;

        }

        localStorage.setItem("token",data.token);

        if(data.username){
            localStorage.setItem("username",data.username);
        }

        showToast(
            "Login successful!",
            "success"
        );

        setTimeout(()=>{

            if(data.isAdmin){
                window.location.href="/admin";
            }else{
                window.location.href="/dashboard";
            }

        },1000);

    }catch(err){

        showToast(
            "Server error. Please try again.",
            "danger"
        );

        loginBtn.disabled=false;
        loginBtn.innerText="Login";

    }

});

</script>

</body>
</html>

