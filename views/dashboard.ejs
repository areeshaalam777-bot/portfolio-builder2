
<!DOCTYPE html>
<html>
<head>
  <title>Dashboard - Portfolio Builder</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>

:root {
  --primary: #2563eb;
  --primary-dark: #1d4ed8;

  --bg: #f8fafc;
  --card: #ffffff;
  --text: #0f172a;

  --muted: #64748b;
  --border: #e2e8f0;
}
    
     body{
  margin:0;
  background: var(--bg);
  font-family: "Segoe UI", sans-serif;
  color: var(--text);
}

   
    
    .sidebar{
  width:240px;
  height:100vh;
  position:fixed;
  background: var(--card);
  border-right:1px solid var(--border);
  padding:20px;
}
    
     .brand{
  font-size:1.3rem;
  font-weight:700;
  color: var(--text);
  margin-bottom:30px;
}

 
     .nav-link{
  display:block;
  padding:10px;
  margin-bottom:8px;
  color: var(--muted);
  text-decoration:none;
  border-radius:10px;
  transition: 0.2s ease;
}


.nav-link.active{
  background: var(--primary);
  color: white;
}

    .main{
      margin-left:260px;
      padding:30px;
    }

    .welcome{
      font-size:1.8rem;
      font-weight:700;
      margin-bottom:5px;
    }

    .subtext{
      color:#6B7280;
      margin-bottom:25px;
    }

    

    .card-box{
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 20px;
  height: 100%;
  transition: 0.3s ease;
  box-shadow: 0 6px 20px rgba(0,0,0,0.04);
}

    
     .stat-number{
  font-size:1.8rem;
  font-weight:700;
  color: var(--text);
}

    .section-title{
      font-size:1.2rem;
      font-weight:600;
      margin-bottom:15px;
    }

    


    .btn-custom{
  background: var(--primary);
  color: white;
  border: none;
  padding: 10px 15px;
  border-radius: 14px;
  text-decoration: none;
  display: inline-block;
  font-weight: 600;
  transition: 0.3s ease;
}

.btn-custom:hover{
  background: var(--primary-dark);
  transform: translateY(-2px);
}
    .card-box:hover{
  transform: translateY(-5px);
  box-shadow: 0 12px 30px rgba(0,0,0,0.08);
}


  </style>
</head>

<body>

<div class="sidebar">

    <div class="brand">
        Portfolio Builder
    </div>

    <a class="nav-link" href="/dashboard">
        📊 Dashboard
    </a>

    <a class="nav-link" href="/profile">
        👤 Profile
    </a>

    <a class="nav-link" href="/projects">
        💼 Projects
    </a>

    <a class="nav-link" id="portfolioLink">
        🌐 Public Portfolio
    </a>

    <hr>

    <a class="nav-link text-danger" href="#" onclick="logout()">
        🚪 Logout
    </a>

</div>

<div class="main">

  <div class="welcome">Welcome Back 👋</div>
  <div class="subtext">Manage your portfolio, projects, and profile</div>

  <div class="row g-4">

    <div class="col-md-4">
      <div class="card-box">
        <div class="section-title">Profile Completion</div>
        <div class="stat-number" id="profileCompletion">0%</div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card-box">
        <div class="section-title">Projects</div>
        <div class="stat-number" id="projectCount">0</div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card-box">
        <div class="section-title">Portfolio Views</div>
        <div class="stat-number" id="portfolioViews">0</div>
      </div>
    </div>

  </div>

  <div class="mt-5">
    <div class="card-box">

      <div class="section-title">Quick Actions</div>

      <a href="/profile" class="btn-custom me-2">Edit Profile</a>
      <a href="/projects" class="btn-custom me-2">Add Project</a>

      <a id="portfolioBtn" class="btn-custom">View Portfolio</a>

    </div>
  </div>

</div>

<script>

const token = localStorage.getItem("token");

async function loadDashboard(){

  const res = await fetch("/api/dashboard",{
    headers:{
      Authorization:"Bearer " + token
    }
  });

  const data = await res.json();

  if(!res.ok) return;

  document.getElementById("projectCount").innerText = data.totalProjects || 0;
  document.getElementById("portfolioViews").innerText = (data.totalProjects || 0) * 5;

  let completion = 0;

  if(data.profile?.username) completion += 20;
  if(data.profile?.bio) completion += 20;
  if(data.profile?.education) completion += 20;
  if(data.profile?.skills?.length) completion += 20;
  if(data.profile?.socialLinks?.github) completion += 20;

  document.getElementById("profileCompletion").innerText = completion + "%";
}


const portfolioUsername = localStorage.getItem("username");

const btn = document.getElementById("portfolioBtn");

if (btn && portfolioUsername) {
  btn.href = `/portfolio/${portfolioUsername}`;
} else if (btn) {
  btn.style.display = "none";
}
const username = localStorage.getItem("username");

const portfolioLink = document.getElementById("portfolioLink");

if (portfolioLink) {
    if (username) {
        portfolioLink.href = `/portfolio/${username}`;
    } else {
        portfolioLink.style.display = "none";
    }
}

function logout() {
    localStorage.removeItem("token");
    localStorage.removeItem("username");
    window.location.href = "/login";
}

</script>

</body>
</html>
